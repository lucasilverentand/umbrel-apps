#!/bin/sh

set -eu

config=${QBITTORRENT_CONFIG_FILE:-/config/qBittorrent/qBittorrent.conf}

if [ ! -f "$config" ]; then
  echo "qBittorrent config is not available yet; skipping Umbrel defaults"
  exit 0
fi

set_preference() {
  key=$1
  value=$2
  temporary=$(mktemp)

  QBIT_KEY="$key" QBIT_VALUE="$value" awk '
    BEGIN {
      key = ENVIRON["QBIT_KEY"]
      value = ENVIRON["QBIT_VALUE"]
      written = 0
    }
    $0 == "[Preferences]" {
      print
      print key "=" value
      written = 1
      next
    }
    index($0, key "=") == 1 { next }
    { print }
    END { if (!written) exit 42 }
  ' "$config" > "$temporary"

  cat "$temporary" > "$config"
  rm -f "$temporary"
}

set_preference 'WebUI\HostHeaderValidation' 'false'
set_preference 'WebUI\ServerDomains' '*'
set_preference 'WebUI\SecureCookie' 'false'
set_preference 'Downloads\SavePath' '/data/complete'
set_preference 'Downloads\TempPath' '/data/incomplete'
set_preference 'Downloads\TempPathEnabled' 'true'

echo "Applied qBittorrent Umbrel WebUI and download-path defaults"
